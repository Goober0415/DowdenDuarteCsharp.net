<Window x:Class="WPFDemo.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="514" Width="525">
	<Grid>
		<!-- Name / ID fields -->
		<Label Content="First:"       Margin="66,50,0,0"  VerticalAlignment="Top" Width="117"/>
		<TextBox x:Name="txbFirstName" Margin="212,50,0,0"  Height="23" Width="258"/>

		<Label Content="Last:"        Margin="66,75,0,0"  VerticalAlignment="Top" Width="117"/>
		<TextBox x:Name="txbLastName"  Margin="212,75,0,0"  Height="23" Width="258"/>

		<Label Content="Student Num:" Margin="66,100,0,0" VerticalAlignment="Top" Width="117"/>
		<TextBox x:Name="txbStudentNum" Margin="212,100,0,0" Height="23" Width="258"/>

		<!-- Major combo box (populated from DB) -->
		<Label Content="Major:"       Margin="66,125,0,0" VerticalAlignment="Top" Width="117"/>
		<ComboBox Name="cbxMajor"      Margin="212,128,0,0" Width="258"/>

		<!-- Score entry area -->
		<Label Content="Scores:"      Margin="66,155,0,0" VerticalAlignment="Top"/>
		<ListBox x:Name="lbScores"     Margin="212,155,0,0" Height="116" Width="258"/>

		<Label Content="Title"         Margin="212,271,0,0" VerticalAlignment="Top"/>
		<Label Content="Score"         Margin="337,271,0,0" VerticalAlignment="Top"/>

		<ComboBox Name="cbxCourse"     Margin="212,298,0,0" Width="125"/>
		<TextBox x:Name="txbScore"     Margin="337,297,0,0" Height="23" Width="80"/>
		<Button  x:Name="btnAdd"       Margin="422,300,0,0" Width="48"
                 Content="Add"         Click="btnAdd_Click"/>

		<!-- Submit -->
		<Button x:Name="btnSubmit"     Margin="180,337,0,0" Width="144"
                Content="Submit"       Click="btnSubmit_Click"/>

		<!-- Result display -->
		<TextBlock x:Name="txbResults" Margin="7,383,0,0"
                   TextWrapping="Wrap"  Height="93" Width="499"/>
	</Grid>
</Window>
