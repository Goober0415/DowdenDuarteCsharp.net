<Window x:Class="WPFDemo.SchoolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SchoolWindow" Height="300" Width="300">
	<Grid>
		<TabControl HorizontalAlignment="Left" Height="271"
                    VerticalAlignment="Top" Width="294"
                    Grid.ColumnSpan="2">

			<!-- CAMPUSES TAB -->
			<TabItem Header="Campuses">
				<Grid Background="#FFE5E5E5">
					<ListBox Name="lbCampuses"
                             HorizontalAlignment="Left"
                             Height="147" VerticalAlignment="Top"
                             Width="287" SelectionMode="Multiple"/>
					<Button Name="btnCampusAddUpdate"
                            Content="Add"
                            HorizontalAlignment="Left"
                            Margin="191,166,0,0"
                            VerticalAlignment="Top" Width="75"
                            Click="Button_Click_1"/>
					<TextBox x:Name="txbCampus"
                             HorizontalAlignment="Left"
                             Height="23" Margin="10,163,0,0"
                             TextWrapping="Wrap" Text="TextBox"
                             VerticalAlignment="Top" Width="176"/>
				</Grid>
			</TabItem>

			<!-- MAJOR TAB -->
			<TabItem Header="Major">
				<Grid Background="#FFE5E5E5">
					<ListBox Name="lbMajor"
                             HorizontalAlignment="Left"
                             Height="243" VerticalAlignment="Top"
                             Width="287"/>
				</Grid>
			</TabItem>

			<!-- COURSES TAB -->
			<TabItem Header="Courses">
				<Grid Background="#FFE5E5E5">
					<ListBox Name="lbCourses"
                             HorizontalAlignment="Left"
                             Height="243" VerticalAlignment="Top"
                             Width="287"/>
				</Grid>
			</TabItem>

			<!-- STUDENTS TAB -->
			<TabItem Header="Students">
				<Grid Background="#FFE5E5E5">
					<ListBox Name="lbStudents"
                             HorizontalAlignment="Left"
                             Height="183" VerticalAlignment="Top"
                             Width="287"
                             SelectionMode="Multiple"/>
					<Button Content="Add Student"
                            HorizontalAlignment="Left"
                            Margin="51,202,0,0"
                            VerticalAlignment="Top"
                            Width="159" Height="31"
                            Click="Button_Click"/>
				</Grid>
			</TabItem>

		</TabControl>
	</Grid>
</Window>